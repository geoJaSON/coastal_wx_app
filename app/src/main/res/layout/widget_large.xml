<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8111827"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Top: large temp (left) + condition / H:L / tiny location (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--°"
            android:textColor="#FFFFFF"
            android:textSize="52sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/widget_cond"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Partly Cloudy"
                android:textColor="#38BDF8"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_hilo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H:-- L:--"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/widget_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#475569"
                android:textSize="9sp"
                android:layout_marginTop="3dp"
                android:singleLine="true" />

        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:text=""
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp" />

    <!-- Key metrics row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_feels_like"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Feels --°"
            android:textColor="#94A3B8"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_wind"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Wind --"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_humidity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hum --%"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:gravity="end" />

    </LinearLayout>

    <!-- Divider before forecast -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:text=""
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp" />

    <!-- Forecast row: day 1 (tomorrow) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/widget_day1_name"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#E2E8F0"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_day1_cond"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#64748B"
            android:textSize="10sp"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_day1_hilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#94A3B8"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Forecast row: day 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="5dp">

        <TextView
            android:id="@+id/widget_day2_name"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#E2E8F0"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_day2_cond"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#64748B"
            android:textSize="10sp"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_day2_hilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#94A3B8"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Forecast row: day 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="5dp">

        <TextView
            android:id="@+id/widget_day3_name"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#E2E8F0"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_day3_cond"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#64748B"
            android:textSize="10sp"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_day3_hilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#94A3B8"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Storm alert ticker (hidden unless active) -->
    <TextView
        android:id="@+id/widget_storm_badge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#EF4444"
        android:padding="3dp"
        android:text="STORM ALERT"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
